# ── Database (Railway MySQL or any cloud MySQL) ───────────────────────────────
# Get from: Railway → your MySQL service → Connect
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_live_...
# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# ── Pricing (in dollars) ──────────────────────────────────────────────────────
PRICE_SINGLE=49
PRICE_AGENCY=99
PRICE_ENTERPRISE=197

# ── Email — Resend ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_...
# Must be a verified domain in Resend
MAIL_FROM=support@yourdomain.com
MAIL_FROM_NAME=CTI WooBundleBoost

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate hash: php -r "echo password_hash('yourpassword', PASSWORD_DEFAULT);"
ADMIN_PASSWORD_HASH=$2y$10$REPLACE_THIS_WITH_YOUR_HASH
# Random 32+ char string — used to sign admin cookies and CSRF tokens
# Generate: php -r "echo bin2hex(random_bytes(32));"
ADMIN_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_URL=https://your-project.vercel.app
SITE_NAME=CTI WooBundleBoost
